{
  "name": "@atomiclabs97/onenote-mcp",
  "version": "0.1.1",
  "description": "MCP server for Microsoft OneNote — read, search, create, and delete pages via Microsoft Graph.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "onenote-mcp": "./dist/cli.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "CHANGELOG.md",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "packageManager": "yarn@1.22.22",
  "scripts": {
    "build": "tsc && tsc-alias",
    "dev": "tsc && tsc-alias && concurrently --kill-others-on-fail --names tsc,alias 'tsc --watch --preserveWatchOutput' 'tsc-alias --watch'",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.scripts.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "smoke": "tsx scripts/smoke.ts",
    "prepublishOnly": "yarn build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "onenote",
    "microsoft-onenote",
    "microsoft-graph",
    "claude",
    "cursor",
    "ai",
    "notes",
    "anthropic"
  ],
  "author": "Ahmad Al Mezaal",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ahmadAlMezaal/onenote-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/ahmadAlMezaal/onenote-mcp/issues"
  },
  "homepage": "https://github.com/ahmadAlMezaal/onenote-mcp#readme",
  "dependencies": {
    "@azure/msal-node": "^2.16.2",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "marked": "^14.1.3",
    "turndown": "^7.2.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "@types/node": "^22.20.0",
    "@types/turndown": "^5.0.5",
    "@vitest/coverage-v8": "2.1.9",
    "concurrently": "^9.2.3",
    "eslint": "^9.14.0",
    "tsc-alias": "^1.9.0",
    "tsx": "^4.23.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^2.1.4"
  }
}
